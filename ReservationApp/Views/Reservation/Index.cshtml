@model List<ReservationViewModel>
@{
    ViewData["Title"] = "Reservations";
}
<h1>Reservations</h1>
<a asp-action="Create" class="btn btn-primary">Nueva Reserva</a>
<table class="table">
    <thead>
        <tr>
            <th>Paciente</th>
            <th>Fecha</th>
            <th>Médico</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var reservation in Model)
        {
            <tr>
                <td>@reservation.Paciente</td>
                <td>@reservation.Fecha.ToString()</td>
                <td>@reservation.Medico</td>
                <td>
                    <form asp-action="Delete" method="post">
                        <input type="hidden" name="id" value="@reservation.Id" />
                        <button type="submit" class="btn btn-danger btn-sm">Eliminar</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>