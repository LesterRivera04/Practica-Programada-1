@model CreateReservationViewModel
@{
    ViewData["Title"] = "Editar Reserva";
}

<h1>Editar Reserva</h1>

<form asp-action="Edit" method="post">
    <input type="hidden" name="id" value="@ViewBag.Id" />

    <div class="form-group">
        <label asp-for="Paciente">Paciente</label>
        <input asp-for="Paciente" class="form-control" />
        <span asp-validation-for="Paciente" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Fecha">Fecha</label>
        <input asp-for="Fecha" type="date" class="form-control" />
        <span asp-validation-for="Fecha" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Medico">Médico</label>
        <input asp-for="Medico" class="form-control" />
        <span asp-validation-for="Medico" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Especialidad">Especialidad</label>
        <input asp-for="Especialidad" class="form-control" />
        <span asp-validation-for="Especialidad" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-warning mt-3">Guardar Cambios</button>
    <a asp-action="Index" class="btn btn-secondary mt-3">Cancelar</a>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}